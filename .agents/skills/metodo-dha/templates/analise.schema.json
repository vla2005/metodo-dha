{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "ConjuntoPerguntasDha",
  "type": "object",
  "required": [
    "reflexaoSequencia",
    "etapas",
    "perguntasIntegradoras",
    "sinalizacaoSeguranca",
    "aviso"
  ],
  "properties": {
    "reflexaoSequencia": {
      "type": "string",
      "maxLength": 1200
    },
    "etapas": {
      "type": "array",
      "minItems": 5,
      "maxItems": 5,
      "items": {
        "type": "object",
        "required": [
          "numeroEtapa",
          "nomeEtapa",
          "perguntas"
        ],
        "properties": {
          "numeroEtapa": {
            "type": "integer",
            "minimum": 1,
            "maximum": 5
          },
          "nomeEtapa": {
            "type": "string",
            "enum": [
              "Circunstância percebida",
              "História",
              "Condicionamentos",
              "Consciência",
              "Escolha consciente"
            ]
          },
          "perguntas": {
            "type": "array",
            "minItems": 1,
            "maxItems": 2,
            "items": {
              "type": "string",
              "maxLength": 500
            }
          }
        },
        "additionalProperties": false
      }
    },
    "perguntasIntegradoras": {
      "type": "array",
      "minItems": 1,
      "maxItems": 2,
      "items": {
        "type": "string",
        "maxLength": 500
      }
    },
    "sinalizacaoSeguranca": {
      "type": "object",
      "required": [
        "requerPausa",
        "requerRevisaoProfissional",
        "motivo"
      ],
      "properties": {
        "requerPausa": {
          "type": "boolean"
        },
        "requerRevisaoProfissional": {
          "type": "boolean"
        },
        "motivo": {
          "type": "string",
          "maxLength": 800
        }
      },
      "additionalProperties": false
    },
    "aviso": {
      "type": "string",
      "maxLength": 700
    }
  },
  "additionalProperties": false
}

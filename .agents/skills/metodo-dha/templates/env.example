NODE_ENV=development
PORT=3000
API_PREFIX=api
FRONTEND_ORIGINS=http://localhost:5173

DATABASE_URL=postgresql://postgres:postgres@localhost:5432/metodo_dha?schema=public

PUBLIC_SESSION_COOKIE_NAME=dha_session
PUBLIC_SESSION_SECRET=troque-este-valor
PUBLIC_SESSION_TTL_HOURS=72
PUBLIC_SESSION_COOKIE_SECURE=false
PUBLIC_SESSION_COOKIE_SAME_SITE=lax
PUBLIC_SESSION_COOKIE_DOMAIN=

RESUME_LINK_ENABLED=false
RESUME_LINK_SECRET=troque-este-valor
RESUME_LINK_TTL_MINUTES=30

# Somente para uma futura área profissional/administrativa restrita.
PROFESSIONAL_JWT_ACCESS_SECRET=troque-este-valor
PROFESSIONAL_JWT_ACCESS_TTL=15m
PROFESSIONAL_JWT_REFRESH_SECRET=troque-este-valor
PROFESSIONAL_JWT_REFRESH_TTL=30d

GEMINI_API_KEY=
GEMINI_MODEL=gemini-3.1-flash-lite
GEMINI_DAILY_HARD_LIMIT=500
GEMINI_DAILY_OPERATIONAL_LIMIT=450
GEMINI_MAX_AYA_ROUNDS=2
GEMINI_TIMEOUT_MS=30000
GEMINI_MAX_RETRIES=1
GEMINI_PROMPT_VERSION=v1
GEMINI_SCHEMA_VERSION=v1

STORAGE_DRIVER=local
STORAGE_BUCKET=metodo-dha
STORAGE_ENDPOINT=
STORAGE_REGION=
STORAGE_ACCESS_KEY=
STORAGE_SECRET_KEY=

LOG_LEVEL=info

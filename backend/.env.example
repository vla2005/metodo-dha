NODE_ENV=development
PORT=3000
API_PREFIX=api
FRONTEND_ORIGINS=http://localhost:5173
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/metodo_dha
DATABASE_POOL_MAX=10
DATABASE_AUTO_SCHEMA=true
DATABASE_SCHEMA_PATH=./sql/schema.sql
CATALOG_DIR=./catalog
CARD_IMAGES_DIR=../imagens
PUBLIC_SESSION_COOKIE_NAME=dha_session
PUBLIC_SESSION_TTL_HOURS=72
PUBLIC_SESSION_COOKIE_SECURE=false
PUBLIC_SESSION_COOKIE_SAME_SITE=lax
AI_PROVIDER=auto
GEMINI_API_KEY=
GEMINI_MODEL=gemini-3.1-flash-lite
GEMINI_DAILY_HARD_LIMIT=500
GEMINI_DAILY_OPERATIONAL_LIMIT=450
GEMINI_TIMEOUT_MS=30000
GEMINI_MAX_RETRIES=1
GEMINI_MAX_OUTPUT_TOKENS=4096
GEMINI_PROMPT_VERSION=questions-v2
GEMINI_SCHEMA_VERSION=questions-v2
GEMINI_ANALYSIS_PROMPT_VERSION=analysis-v2
GEMINI_ANALYSIS_SCHEMA_VERSION=analysis-v2
LOG_LEVEL=info

# Informe estas duas variáveis no Coolify antes do primeiro deploy.
APP_URL=https://metodo-dha.viktorware.com
GEMINI_API_KEY=substitua_pela_chave_real

# O Coolify gera esta variável ao recarregar o Compose; não a crie vazia.
SERVICE_PASSWORD_POSTGRES=gerada_automaticamente_pelo_coolify

# Valores opcionais; o Compose já possui estes padrões.
POSTGRES_DB=metodo_dha
POSTGRES_USER=metodo_dha
DATABASE_POOL_MAX=5
PUBLIC_SESSION_TTL_HOURS=72
AI_PROVIDER=gemini
GEMINI_MODEL=gemini-3.1-flash-lite
GEMINI_DAILY_HARD_LIMIT=500
GEMINI_DAILY_OPERATIONAL_LIMIT=450
GEMINI_TIMEOUT_MS=90000
GEMINI_MAX_RETRIES=1
GEMINI_MAX_OUTPUT_TOKENS=12288
GEMINI_PROMPT_VERSION=questions-v2
GEMINI_SCHEMA_VERSION=questions-v2
GEMINI_ANALYSIS_PROMPT_VERSION=analysis-v2
GEMINI_ANALYSIS_SCHEMA_VERSION=analysis-v2
LOG_LEVEL=info
